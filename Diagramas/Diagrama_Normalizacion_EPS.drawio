<mxfile host="app.diagrams.net">
  <diagram name="Normalizacion EPS" id="normalizacion-diagram">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1100">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- TITULO -->
        <mxCell id="titulo" value="ANÁLISIS DE NORMALIZACIÓN - SISTEMA EPS" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="20" width="400" height="40" as="geometry"/>
        </mxCell>

        <!-- 1NF -->
        <mxCell id="1nf_title" value="1ª FORMA NORMAL (1NF)" style="text;html=1;strokeColor=none;fillColor=#dae8fc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#1939cc;" vertex="1" parent="1">
          <mxGeometry x="50" y="80" width="380" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="1nf_box" value="✅ CUMPLE" style="shape=check;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#2e7d32;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="78" width="80" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="1nf_content" value="• Todos los atributos son atómicos (valores indivisibles)&#xa;• No existen grupos repetitivos&#xa;• Cada tabla tiene clave primaria única&#xa;&#xa;Ejemplo:&#xa;- documento en afiliados es VARCHAR(20) simple&#xa;- email en usuarios es un valor único e indivisible&#xa;- telefono en afiliados es atómico (no分成número + código país)" style="text;html=1;strokeColor=#6c8ebf;fillColor=#f3f6fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacing=5;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="50" y="115" width="380" height="130" as="geometry"/>
        </mxCell>

        <!-- 2NF -->
        <mxCell id="2nf_title" value="2ª FORMA NORMAL (2NF)" style="text;html=1;strokeColor=none;fillColor=#fff2cc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#996600;" vertex="1" parent="1">
          <mxGeometry x="470" y="80" width="380" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="2nf_box" value="⚠️ CUMPLE" style="shape=check;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#998800;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="770" y="78" width="80" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="2nf_content" value="• Está en 1NF&#xa;• Todos los atributos no clave dependen completamente de la PK&#xa;&#xa;Caso especial - Afiliados:&#xa;- PK simple: id_afiliado&#xa;- documento y tipo_documento juntos forman un identificador natural&#xa;- telefono es UNIQUE pero es un atributo, no parte de la PK&#xa;- No hay dependencia parcial (todos dependen de id_afiliado)&#xa;&#xa;Caso Profesional:&#xa;- PK simple: id_profesional&#xa;- especialidad depende completamente de id_profesional" style="text;html=1;strokeColor=#d6b656;fillColor=#fffdf0;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacing=5;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="470" y="115" width="380" height="130" as="geometry"/>
        </mxCell>

        <!-- 3NF -->
        <mxCell id="3nf_title" value="3ª FORMA NORMAL (3NF)" style="text;html=1;strokeColor=none;fillColor=#f8cecc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#a8231f;" vertex="1" parent="1">
          <mxGeometry x="890" y="80" width="380" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="3nf_box" value="✅ CUMPLE" style="shape=check;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#2e7d32;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="1190" y="78" width="80" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="3nf_content" value="• Está en 2NF&#xa;• No existen dependencias transitivas&#xa;&#xa;Análisis:&#xa;- En usuarios: rol no depende transitivamente de id_usuario&#xa;- El rol es un valor del enum directamente del usuario&#xa;- No hay atributos que dependan de otros atributos no clave&#xa;&#xa;Nota: Para ADMIN no existe tabla separada, pero el rol&#xa;sirve como discriminator. Esto es una decisión de diseño&#xa;que mantiene la normalización." style="text;html=1;strokeColor=#b85450;fillColor=#fff5f5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacing=5;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="890" y="115" width="380" height="130" as="geometry"/>
        </mxCell>

        <!-- TABLA: usuarios (analisis) -->
        <mxCell id="analisis_usuarios" value="ANÁLISIS: usuarios" style="shape=table;startSize=30;container=1;collapsible=1;childLayout=tableLayout;fixedRows=1;rowLines=0;fontStyle=1;align=center;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="50" y="270" width="400" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="analisis_usuarios_pk" value="PK: id_usuario" style="shape=column;part=1;collapsible=0;columnHeader=no;html=1;whiteSpace=wrap;align=left;spacingLeft=5;fontStyle=5;fillColor=#D4E157;strokeColor=#827717;" vertex="1" parent="analisis_usuarios">
          <mxGeometry y="30" width="400" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="analisis_usuarios_row1" value="Atributos: nombre, email, password, rol" style="shape=column;part=1;collapsible=0;columnHeader=no;html=1;whiteSpace=wrap;align=left;spacingLeft=5;" vertex="1" parent="analisis_usuarios">
          <mxGeometry y="55" width="400" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="analisis_usuarios_row2" value="Dependencias:&#xa;- id_usuario → nombre, email, password, rol&#xa;- email → id_usuario (unique)" style="shape=column;part=1;collapsible=0;columnHeader=no;html=1;whiteSpace=wrap;align=left;spacingLeft=5;" vertex="1" parent="analisis_usuarios">
          <mxGeometry y="80" width="400" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="analisis_usuarios_row3" value="Normalización: 3NF ✅" style="shape=column;part=1;collapsible=0;columnHeader=no;html=1;whiteSpace=wrap;align=left;spacingLeft=5;fillColor=#d5e8d4;" vertex="1" parent="analisis_usuarios">
          <mxGeometry y="125" width="400" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="analisis_usuarios_row4" value="Notas: email es UNIQUE. Relación 1:1 con afiliados (unique FK)&#xa;Relación 1:N con profesionales." style="shape=column;part=1;collapsible=0;columnHeader=no;html=1;whiteSpace=wrap;align=left;spacingLeft=5;" vertex="1" parent="analisis_usuarios">
          <mxGeometry y="150" width="400" height="30" as="geometry"/>
        </mxCell>

        <!-- TABLA: afiliados (analisis) -->
        <mxCell id="analisis_afiliados" value="ANÁLISIS: afiliados" style="shape=table;startSize=30;container=1;collapsible=1;childLayout=tableLayout;fixedRows=1;rowLines=0;fontStyle=1;align=center;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="470" y="270" width="400" height="170" as="geometry"/>
        </mxCell>
        <mxCell id="analisis_afiliados_pk" value="PK: id_afiliado" style="shape=column;part=1;collapsible=0;columnHeader=no;html=1;whiteSpace=wrap;align=left;spacingLeft=5;fontStyle=5;fillColor=#D4E157;strokeColor=#827717;" vertex="1" parent="analisis_afiliados">
          <mxGeometry y="30" width="400" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="analisis_afiliados_row1" value="Atributos: tipo_documento, documento, fecha_nac, telefono, direccion" style="shape=column;part=1;collapsible=0;columnHeader=no;html=1;whiteSpace=wrap;align=left;spacingLeft=5;" vertex="1" parent="analisis_afiliados">
          <mxGeometry y="55" width="400" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="analisis_afiliados_row2" value="Dependencias:&#xa;- id_afiliado → todos los atributos&#xa;- (tipo_documento, documento) → id_afiliado (identificador natural)&#xa;- telefono → id_afiliado (unique)" style="shape=column;part=1;collapsible=0;columnHeader=no;html=1;whiteSpace=wrap;align=left;spacingLeft=5;" vertex="1" parent="analisis_afiliados">
          <mxGeometry y="80" width="400" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="analisis_afiliados_row3" value="Normalización: 3NF ✅" style="shape=column;part=1;collapsible=0;columnHeader=no;html=1;whiteSpace=wrap;align=left;spacingLeft=5;fillColor=#d5e8d4;" vertex="1" parent="analisis_afiliados">
          <mxGeometry y="125" width="400" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="analisis_afiliados_row4" value="FK: id_usuario (UNIQUE → 1:1), id_plan (N:1)&#xa;Notas: documento + tipo_documento = identificador natural único." style="shape=column;part=1;collapsible=0;columnHeader=no;html=1;whiteSpace=wrap;align=left;spacingLeft=5;" vertex="1" parent="analisis_afiliados">
          <mxGeometry y="150" width="400" height="30" as="geometry"/>
        </mxCell>

        <!-- TABLA: citas (analisis) -->
        <mxCell id="analisis_citas" value="ANÁLISIS: citas" style="shape=table;startSize=30;container=1;collapsible=1;childLayout=tableLayout;fixedRows=1;rowLines=0;fontStyle=1;align=center;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
