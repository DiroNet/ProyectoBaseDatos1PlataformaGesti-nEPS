        <mxCell id="analisis_citas_pk" value="PK: id_cita" style="shape=column;part=1;collapsible=0;columnHeader=no;html=1;whiteSpace=wrap;align=left;spacingLeft=5;fontStyle=5;fillColor=#D4E157;strokeColor=#827717;" vertex="1" parent="analisis_citas">
          <mxGeometry y="30" width="400" height="25" as="geometry"/>
