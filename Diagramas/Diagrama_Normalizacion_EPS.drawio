        <mxCell id="analisis_citas_row4" value="Notas: Tabla pivote con 3 FK. Relación N:1 con&#xa;afiliados, profesionales y centros_salud." style="shape=column;part=1;collapsible=0;columnHeader=no;html=1;whiteSpace=wrap;align=left;spacingLeft=5;" vertex="1" parent="analisis_citas">
