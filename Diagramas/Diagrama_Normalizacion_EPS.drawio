        <mxCell id="analisis_citas_row1" value="Atributos: fecha, estado" style="shape=column;part=1;collapsible=0;columnHeader=no;html=1;whiteSpace=wrap;align=left;spacingLeft=5;" vertex="1" parent="analisis_citas">
