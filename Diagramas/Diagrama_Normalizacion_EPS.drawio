        <mxCell id="analisis_citas_row2" value="Dependencias:&#xa;- id_cita → fecha, estado&#xa;- FK: id_afiliado, id_profesional, id_centro&#xa;- (id_afiliado, id_profesional, fecha) → id_cita (única)" style="shape=column;part=1;collapsible=0;columnHeader=no;html=1;whiteSpace=wrap;align=left;spacingLeft=5;" vertex="1" parent="analisis_citas">
          <mxGeometry y="80" width="400" height="45" as="geometry"/>
